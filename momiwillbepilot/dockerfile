# Doporučený způsob: Multi-stage build s konkrétní verzí SDK

# --- Fáze 1: Sestavení Flutter aplikace (Builder) ---
FROM alpine:3.19 AS builder

# Argument pro snadnou změnu verze Flutteru
ARG FLUTTER_VERSION=3.35.4
ENV FLUTTER_URL="https://storage.googleapis.com/flutter_infra_release/releases/stable/linux/flutter_linux_${FLUTTER_VERSION}-stable.tar.xz"

# Instalace závislostí potřebných pro stažení, rozbalení a sestavení
RUN apk update && apk add --no-cache \
    bash \
    wget \
    xz \
    tar \
    gcompat \
    git

# Stažení a rozbalení Flutter SDK do /opt
RUN wget ${FLUTTER_URL} -q -O flutter.tar.xz && \
    mkdir -p /opt/flutter 

RUN tar -xf flutter.tar.xz -C /opt/ && \
    rm flutter.tar.xz

# Nastavení cesty, aby bylo možné volat 'flutter'
ENV PATH="/opt/flutter/bin:${PATH}"


RUN git config --global --add safe.directory /opt/flutter
# Povolení webové podpory
RUN flutter config --enable-web

# Zkopírování závislostí a jejich stažení (optimalizace pro Docker cache)
WORKDIR /app
COPY pubspec.yaml pubspec.lock ./
RUN flutter pub get

# Zkopírování zbytku aplikace a její sestavení
COPY . .
RUN flutter build web --release


# --- Fáze 2: Servírování statických souborů (Server) ---
# Použití velmi malého a efektivního Nginx serveru na Alpine
FROM nginx:1.29-alpine

# Odstranění výchozího obsahu Nginx
RUN rm -rf /usr/share/nginx/html/*

# Zkopírování sestavených souborů z 'builder' fáze
COPY --from=builder /app/build/web /usr/share/nginx/html

# (Volitelné, ale doporučené) Přidání vlastní konfigurace Nginx pro Flutter (SPA)
# Soubor `nginx.conf` musí existovat vedle vašeho Dockerfile.
# COPY nginx.conf /etc/nginx/conf.d/default.conf

# Server poběží na portu 80 uvnitř kontejneru
EXPOSE 80

# Příkaz pro spuštění Nginx je již součástí základního obrazu
CMD ["nginx", "-g", "daemon off;"]