# --- Fáze 1: Sestavení Flutter aplikace ---
FROM alpine:3.19 AS builder

ARG FLUTTER_VERSION=3.41.4
ENV FLUTTER_URL="https://storage.googleapis.com/flutter_infra_release/releases/stable/linux/flutter_linux_${FLUTTER_VERSION}-stable.tar.xz"

RUN apk update && apk add --no-cache bash wget xz tar gcompat git

RUN wget ${FLUTTER_URL} -q -O flutter.tar.xz && \
    mkdir -p /opt/flutter && \
    tar -xf flutter.tar.xz -C /opt/ && \
    rm flutter.tar.xz

ENV PATH="/opt/flutter/bin:${PATH}"
RUN git config --global --add safe.directory /opt/flutter
RUN flutter config --enable-web

WORKDIR /app
COPY pubspec.yaml pubspec.lock ./
RUN flutter pub get
COPY . .

# Build aplikace
RUN flutter clean && \
    flutter build web --release

# TRIK: Kopírování assetů o úroveň výš, aby byly dostupné na obou cestách
# (assets/unique_questions.json i assets/assets/unique_questions.json)
RUN if [ -d "build/web/assets/assets" ]; then \
    cp -r build/web/assets/assets/* build/web/assets/; \
    fi

# --- Fáze 2: Servírování s Nginxem ---
FROM nginx:1.29-alpine

# Vytvoření standardní funkční konfigurace pro SPA
RUN echo 'server { \
    listen 80; \
    root /usr/share/nginx/html; \
    index index.html; \
    location / { \
        try_files $uri $uri/ /index.html; \
    } \
    # Zakázání cache pro JSON a HTML \
    location ~* \.(html|json)$ { \
        add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"; \
        expires -1; \
    } \
}' > /etc/nginx/conf.d/default.conf

RUN rm -rf /usr/share/nginx/html/*
COPY --from=builder /app/build/web /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
